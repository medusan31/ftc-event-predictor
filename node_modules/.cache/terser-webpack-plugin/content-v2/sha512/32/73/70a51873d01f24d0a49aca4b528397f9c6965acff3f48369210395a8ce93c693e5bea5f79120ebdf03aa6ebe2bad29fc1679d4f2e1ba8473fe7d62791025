BAAA,CAAC6H,eAAK,CAACC,UAAU,EAAA/H,QAAA,cACfC,0BAAA,CAACwH,OAAG,GAAE,CAAC,CACS,CAAC,CACnBlJ,QAAQ,CAACyJ,cAAc,CAAC,MAAM,CAChC,CAAC,C;;;;;;;ACVD,uC","file":"x","sourcesContent":["// extracted by mini-css-extract-plugin","// extracted by mini-css-extract-plugin","import { EventSearchResult, RawEventData } from '../types';\n\nconst API_URL = 'https://api.ftcscout.org/graphql';\n\nasync function gql(query: string, variables: Record<string, unknown> = {}): Promise<any> {\n  const res = await fetch(API_URL, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ query, variables }),\n  });\n\n  if (!res.ok) {\n    throw new Error(`API error ${res.status}: ${res.statusText}`);\n  }\n\n  const json = await res.json();\n\n  if (json.errors?.length) {\n    throw new Error(json.errors.map((e: any) => e.message).join('; '));\n  }\n\n  return json.data;\n}\n\nexport const SEASONS = [\n  { label: '2025-2026', value: 2025 },\n  { label: '2024-2025', value: 2024 },\n  { label: '2023-2024', value: 2023 },\n  { label: '2022-2023', value: 2022 },\n  { label: '2021-2022', value: 2021 },\n];\n\nexport async function searchEvents(query: string, season: number): Promise<EventSearchResult[]> {\n  if (!query || query.trim().length < 2) return [];\n\n  const data = await gql(\n    `query SearchEvents($season: Int!, $query: String!) {\n      eventsSearch(season: $season, query: $query) {\n        code\n        name\n        start\n        end\n        location { venue city state country }\n        type\n      }\n    }`,\n    { season, query: query.trim() }\n  );\n\n  return (data.eventsSearch || []).map((e: any) => ({ ...e, season }));\n}\n\nexport async function getEventDetails(code: string, season: number): Promise<RawEventData> {\n  const data = await gql(\n    `query GetEvent($season: Int!, $code: String!) {\n      eventByCode(season: $season, code: $code) {\n        code\n        name\n        start\n        end\n        hasResults\n        location { venue city state country }\n        teams {\n          teamNumber\n          opr { total auto teleop endgame }\n        }\n        matches {\n          matchNum\n          hasBeenPlayed\n          teams { teamNumber station surrogate noShow dq }\n          scores {\n            red { totalPoints }\n            blue { totalPoints }\n          }\n        }\n      }\n    }`,\n    { season, code }\n  );\n\n  const event = data.eventByCode;\n  if (!event) throw new Error(`Event \"${code}\" not found for season ${season}`);\n  return event;\n}\n\nexport function extractScore(score: any): number {\n  if (!score) return 0;\n  return score.totalPoints ?? score.total ?? score.totalPointsNp ?? 0;\n}\n\nexport function getTeamAlliance(station: string): 'red' | 'blue' | null {\n  const s = station.toLowerCase();\n  if (s.startsWith('red') || s === 'r1' || s === 'r2') return 'red';\n  if (s.startsWith('blue') || s === 'b1' || s === 'b2') return 'blue';\n  return null;\n}\n\nasync function fetchTeamSeasonBestOPR(teamNumber: number, season: number): Promise<number> {\n  const data = await gql(\n    `query GetTeamSeason($number: Int!, $season: Int!) {\n      teamByNumber(number: $number) {\n        events(season: $season) {\n          opr { total }\n        }\n      }\n    }`,\n    { number: teamNumber, season }\n  );\n\n  const events: any[] = data?.teamByNumber?.events ?? [];\n  const oprs = events\n    .map((e: any) => e?.opr?.total ?? 0)\n    .filter((o: number) => typeof o === 'number' && o > 0);\n\n  return oprs.length > 0 ? Math.max(...oprs) : 0;\n}\n\nexport async function loadTeamBestOPRs(\n  teamNumbers: number[],\n  season: number,\n  eventOPRFallback: Map<number, number>\n): Promise<Map<number, number>> {\n  const settled = await Promise.allSettled(\n    teamNumbers.map(num => fetchTeamSeasonBestOPR(num, season))\n  );\n\n  const result = new Map<number, number>();\n  teamNumbers.forEach((num, i) => {\n    const r = settled[i];\n    const seasonBest = r.status === 'fulfilled' ? r.value : 0;\n    const fallback = eventOPRFallback.get(num) ?? 0;\n    result.set(num, seasonBest > 0 ? seasonBest : fallback);\n  });\n\n  return result;\n}\n\n// Legacy exports kept for backward compatibility\nexport const fetchEventData = async (eventName: string) => ({\n  name: eventName,\n  location: 'Location TBD',\n  date: 'Date TBD',\n  matches: [],\n});\n\nexport const fetchEventsByName = searchEvents;\n","import React, { useState, useEffect, useRef, useCallback } from 'react';\nimport { searchEvents, SEASONS } from '../services/ftcScoutApi';\nimport { EventSearchResult } from '../types';\nimport '../styles/EventSearch.css';\n\ninterface EventSearchProps {\n  onEventSelect: (event: EventSearchResult) => void;\n}\n\nconst EventSearch: React.FC<EventSearchProps> = ({ onEventSelect }) => {\n  const [season, setSeason] = useState(SEASONS[0].value);\n  const [query, setQuery] = useState('');\n  const [suggestions, setSuggestions] = useState<EventSearchResult[]>([]);\n  const [loading, setLoading] = useState(false);\n  const [showDropdown, setShowDropdown] = useState(false);\n  const [activeIndex, setActiveIndex] = useState(-1);\n  const debounceRef = useRef<ReturnType<typeof setTimeout> | null>(null);\n  const containerRef = useRef<HTMLDivElement>(null);\n  const inputRef = useRef<HTMLInputElement>(null);\n\n  const fetchSuggestions = useCallback(async (q: string, s: number) => {\n    if (q.trim().length < 2) {\n      setSuggestions([]);\n      setShowDropdown(false);\n      return;\n    }\n    setLoading(true);\n    try {\n      const results = await searchEvents(q, s);\n      setSuggestions(results);\n      setShowDropdown(results.length > 0);\n    } catch {\n      setSuggestions([]);\n      setShowDropdown(false);\n    } finally {\n      setLoading(false);\n    }\n  }, []);\n\n  useEffect(() => {\n    if (debounceRef.current) clearTimeout(debounceRef.current);\n    debounceRef.current = setTimeout(() => fetchSuggestions(query, season), 320);\n    return () => {\n      if (debounceRef.current) clearTimeout(debounceRef.current);\n    };\n  }, [query, season, fetchSuggestions]);\n\n  useEffect(() => {\n    const handler = (e: MouseEvent) => {\n      if (containerRef.current && !containerRef.current.contains(e.target as Node)) {\n        setShowDropdown(false);\n      }\n    };\n    document.addEventListener('mousedown', handler);\n    return () => document.removeEventListener('mousedown', handler);\n  }, []);\n\n  const handleKeyDown = (e: React.KeyboardEvent) => {\n    if (!showDropdown || suggestions.length === 0) return;\n    if (e.key === 'ArrowDown') {\n      e.preventDefault();\n      setActiveIndex(i => Math.min(i + 1, suggestions.length - 1));\n    } else if (e.key === 'ArrowUp') {\n      e.preventDefault();\n      setActiveIndex(i => Math.max(i - 1, 0));\n    } else if (e.key === 'Enter' && activeIndex >= 0) {\n      e.preventDefault();\n      selectEvent(suggestions[activeIndex]);\n    } else if (e.key === 'Escape') {\n      setShowDropdown(false);\n    }\n  };\n\n  const selectEvent = (event: EventSearchResult) => {\n    setQuery(event.name);\n    setShowDropdown(false);\n    setActiveIndex(-1);\n    onEventSelect(event);\n  };\n\n  const fmtDate = (d: string) => {\n    try {\n      return new Date(d).toLocaleDateString('en-US', {\n        month: 'short', day: 'numeric', year: 'numeric',\n      });\n    } catch {\n      return d;\n    }\n  };\n\n  const locationStr = (loc: EventSearchResult['location']) =>\n    [loc.city, loc.state, loc.country].filter(Boolean).join(', ');\n\n  return (\n    <div className=\"event-search-container neon-card\" ref={containerRef}>\n      <h2 className=\"section-title\">Find an Event</h2>\n\n      <div className=\"search-controls\">\n        <div className=\"year-selector\">\n          <label htmlFor=\"season-select\">Season</label>\n          <select\n            id=\"season-select\"\n            value={season}\n            onChange={e => {\n              setSeason(Number(e.target.value));\n              setQuery('');\n              setSuggestions([]);\n              setShowDropdown(false);\n            }}\n          >\n            {SEASONS.map(s => (\n              <option key={s.value} value={s.value}>{s.label}</option>\n            ))}\n          </select>\n        </div>\n\n        <div className=\"search-input-wrapper\">\n          <div className=\"input-row\">\n            <span className=\"search-icon-glyph\">⚡</span>\n            <input\n              ref={inputRef}\n              type=\"text\"\n              value={query}\n              onChange={e => { setQuery(e.target.value); setActiveIndex(-1); }}\n              onFocus={() => suggestions.length > 0 && setShowDropdown(true)}\n              onKeyDown={handleKeyDown}\n              placeholder=\"Start typing an event name...\"\n              autoComplete=\"off\"\n              spellCheck={false}\n            />\n            {loading && <span className=\"spinner-dot\" aria-label=\"Searching\" />}\n          </div>\n\n          {showDropdown && (\n            <ul className=\"autocomplete-dropdown\" role=\"listbox\">\n              {suggestions.map((ev, idx) => (\n                <li\n                  key={ev.code}\n                  role=\"option\"\n                  aria-selected={idx === activeIndex}\n                  className={`autocomplete-item${idx === activeIndex ? ' active' : ''}`}\n                  onMouseDown={() => selectEvent(ev)}\n                  onMouseEnter={() => setActiveIndex(idx)}\n                >\n                  <span className=\"ev-name\">{ev.name}</span>\n                  <span className=\"ev-meta\">\n                    <span className=\"ev-location\">📍 {locationStr(ev.location)}</span>\n                    <span className=\"ev-date\">📅 {fmtDate(ev.start)}</span>\n                  </span>\n                </li>\n              ))}\n            </ul>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n};\n\nexport default EventSearch;\n","import React from 'react';\nimport { PredictedMatch } from '../types';\nimport { ViewMode } from './EventView';\n\ninterface MatchCardProps {\n  match: PredictedMatch;\n  viewMode: ViewMode;\n  teamOPRs: Map<number, number>;\n}\n\nconst MatchCard: React.FC<MatchCardProps> = ({ match, viewMode, teamOPRs }) => {\n  const useActual = viewMode === 'actual' && match.hasBeenPlayed;\n  const winner = useActual ? match.actualWinner : match.predictedWinner;\n  const redScore = useActual ? match.actualRedScore : match.redPredictedScore;\n  const blueScore = useActual ? match.actualBlueScore : match.bluePredictedScore;\n  const showOPR = !useActual;\n\n  const cardClass = [\n    'match-card',\n    winner === 'red' ? 'mc-red-win' : winner === 'blue' ? 'mc-blue-win' : '',\n    !match.hasBeenPlayed ? 'mc-upcoming' : '',\n  ].filter(Boolean).join(' ');\n\n  return (\n    <div className={cardClass}>\n      <div className=\"mc-header\">\n        <span className=\"mc-num\">Match {match.matchNum}</span>\n        <span className={`mc-badge ${match.hasBeenPlayed ? 'badge-played' : 'badge-upcoming'}`}>\n          {match.hasBeenPlayed ? 'PLAYED' : 'UPCOMING'}\n        </span>\n      </div>\n\n      <div className=\"mc-body\">\n        <AllianceBlock\n          color=\"red\"\n          teams={match.redTeams}\n          score={redScore}\n          isWinner={winner === 'red'}\n          showOPR={showOPR}\n          teamOPRs={teamOPRs}\n          useActual={useActual}\n        />\n\n        <div className=\"mc-vs\">\n          <span className=\"vs-text\">VS</span>\n          {winner === 'red' && <span className=\"arrow-left\">◄</span>}\n          {winner === 'blue' && <span className=\"arrow-right\">►</span>}\n        </div>\n\n        <AllianceBlock\n          color=\"blue\"\n          teams={match.blueTeams}\n          score={blueScore}\n          isWinner={winner === 'blue'}\n          showOPR={showOPR}\n          teamOPRs={teamOPRs}\n          useActual={useActual}\n        />\n      </div>\n\n      {winner && (\n        <div className=\"mc-footer\">\n          <span className={`win-badge wb-${winner === 'tie' ? 'tie' : winner}`}>\n            {winner === 'tie' ? '🤝 TIE' : `${winner.toUpperCase()} WINS`}\n          </span>\n        </div>\n      )}\n    </div>\n  );\n};\n\ninterface AllianceBlockProps {\n  color: 'red' | 'blue';\n  teams: number[];\n  score: number | undefined;\n  isWinner: boolean;\n  showOPR: boolean;\n  teamOPRs: Map<number, number>;\n  useActual: boolean;\n}\n\nconst AllianceBlock: React.FC<AllianceBlockProps> = ({\n  color, teams, score, isWinner, showOPR, teamOPRs, useActual,\n}) => (\n  <div className={`alliance-blk ab-${color}${isWinner ? ' ab-winner' : ''}`}>\n    <div className={`ab-label ab-label-${color}`}>{color.toUpperCase()}</div>\n    <div className=\"ab-teams\">\n      {teams.map(num => (\n        <div key={num} className={`team-pill tp-${color}`}>\n          <span className=\"tp-num\">#{num}</span>\n          {showOPR && (\n            <span className=\"tp-opr\">{(teamOPRs.get(num) ?? 0).toFixed(1)}</span>\n          )}\n        </div>\n      ))}\n    </div>\n    <div className={`ab-score score-${color}${isWinner ? ' score-winner' : ''}`}>\n      {score != null\n        ? useActual\n          ? Math.round(score)\n          : score.toFixed(1)\n        : '—'}\n    </div>\n    {showOPR && (\n      <div className=\"ab-opr-label\">OPR sum</div>\n    )}\n  </div>\n);\n\nexport default MatchCard;\n","import React from 'react';\nimport MatchCard from './MatchCard';\nimport { PredictedMatch } from '../types';\nimport { ViewMode } from './EventView';\n\ninterface MatchListProps {\n  matches: PredictedMatch[];\n  viewMode: ViewMode;\n  teamOPRs: Map<number, number>;\n}\n\nconst MatchList: React.FC<MatchListProps> = ({ matches, viewMode, teamOPRs }) => {\n  if (matches.length === 0) {\n    return (\n      <div className=\"no-data-msg\">\n        No qualification matches found for this event.\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"match-list\">\n      <h3 className=\"panel-title\">\n        {viewMode === 'predicted' ? '🔮 Match Predictions' : '📊 Match Results'}\n      </h3>\n      <div className=\"match-grid\">\n        {matches.map(m => (\n          <MatchCard\n            key={m.matchNum}\n            match={m}\n            viewMode={viewMode}\n            teamOPRs={teamOPRs}\n          />\n        ))}\n      </div>\n    </div>\n  );\n};\n\nexport default MatchList;\n","import React from 'react';\nimport { TeamStanding } from '../types';\nimport { ViewMode } from './EventView';\n\ninterface TeamRankingsProps {\n  standings: TeamStanding[];\n  viewMode: ViewMode;\n}\n\nconst RANK_ICONS = ['🥇', '🥈', '🥉'];\n\nconst TeamRankings: React.FC<TeamRankingsProps> = ({ standings, viewMode }) => {\n  const sorted = [...standings].sort((a, b) => {\n    const aW = viewMode === 'predicted' ? a.predictedWins : a.actualWins;\n    const bW = viewMode === 'predicted' ? b.predictedWins : b.actualWins;\n    if (bW !== aW) return bW - aW;\n    return b.opr - a.opr;\n  });\n\n  return (\n    <div className=\"team-rankings\">\n      <h3 className=\"panel-title\">\n        {viewMode === 'predicted' ? '🔮 Predicted Rankings' : '📊 Actual Rankings'}\n      </h3>\n      <div className=\"rankings-scroll\">\n        <table className=\"rankings-table\">\n          <thead>\n            <tr>\n              <th>#</th>\n              <th>Team</th>\n              <th>W</th>\n              <th>L</th>\n              <th>T</th>\n              <th>OPR</th>\n            </tr>\n          </thead>\n          <tbody>\n            {sorted.map((team, idx) => {\n              const wins   = viewMode === 'predicted' ? team.predictedWins   : team.actualWins;\n              const losses = viewMode === 'predicted' ? team.predictedLosses : team.actualLosses;\n              const ties   = viewMode === 'predicted' ? team.predictedTies   : team.actualTies;\n\n              return (\n                <tr\n                  key={team.teamNumber}\n                  className={idx < 3 ? `top-row rank-${idx + 1}` : ''}\n                >\n                  <td className=\"cell-rank\">\n                    {idx < 3 ? RANK_ICONS[idx] : idx + 1}\n                  </td>\n                  <td className=\"cell-team\">#{team.teamNumber}</td>\n                  <td className=\"cell-w\">{wins}</td>\n                  <td className=\"cell-l\">{losses}</td>\n                  <td className=\"cell-t\">{ties}</td>\n                  <td className=\"cell-opr\">{team.opr.toFixed(1)}</td>\n                </tr>\n              );\n            })}\n          </tbody>\n        </table>\n      </div>\n    </div>\n  );\n};\n\nexport default TeamRankings;\n","import React, { useEffect, useState, useMemo } from 'react';\nimport {\n  getEventDetails,\n  loadTeamBestOPRs,\n  extractScore,\n  getTeamAlliance,\n} from '../services/ftcScoutApi';\nimport { PredictedMatch, RawEventData, TeamStanding } from '../types';\nimport MatchList from './MatchList';\nimport TeamRankings from './TeamRankings';\n\ninterface EventViewProps {\n  eventCode: string;\n  season: number;\n  eventName: string;\n}\n\nexport type ViewMode = 'predicted' | 'actual';\n\nconst EventView: React.FC<EventViewProps> = ({ eventCode, season }) => {\n  const [eventData, setEventData] = useState<RawEventData | null>(null);\n  const [teamOPRs, setTeamOPRs] = useState<Map<number, number>>(new Map());\n  const [loading, setLoading] = useState(true);\n  const [loadingOPRs, setLoadingOPRs] = useState(false);\n  const [error, setError] = useState<string | null>(null);\n  const [viewMode, setViewMode] = useState<ViewMode>('predicted');\n\n  useEffect(() => {\n    let cancelled = false;\n\n    const run = async () => {\n      setLoading(true);\n      setError(null);\n      setEventData(null);\n      setTeamOPRs(new Map());\n\n      try {\n        const data = await getEventDetails(eventCode, season);\n        if (cancelled) return;\n        setEventData(data);\n        setLoading(false);\n\n        // Collect all unique team numbers from matches\n        const teamNums = new Set<number>();\n        for (const m of data.matches ?? []) {\n          for (const t of m.teams ?? []) teamNums.add(t.teamNumber);\n        }\n\n        // Build event-level OPR fallback map\n        const eventOPRFallback = new Map<number, number>();\n        for (const t of data.teams ?? []) {\n          eventOPRFallback.set(t.teamNumber, t.opr?.total ?? 0);\n        }\n\n        setLoadingOPRs(true);\n        const best = await loadTeamBestOPRs(Array.from(teamNums), season, eventOPRFallback);\n        if (cancelled) return;\n        setTeamOPRs(best);\n      } catch (err) {\n        if (!cancelled) {\n          setError((err as Error).message ?? 'Failed to load event');\n          setLoading(false);\n        }\n      } finally {\n        if (!cancelled) setLoadingOPRs(false);\n      }\n    };\n\n    run();\n    return () => { cancelled = true; };\n  }, [eventCode, season]);\n\n  const qualMatches = useMemo(() => {\n    if (!eventData?.matches) return [];\n    return [...eventData.matches].sort((a, b) => a.matchNum - b.matchNum);\n  }, [eventData]);\n\n  const predictedMatches = useMemo((): PredictedMatch[] =>\n    qualMatches.map(match => {\n      const redTeams = match.teams\n        .filter(t => getTeamAlliance(t.station) === 'red')\n        .map(t => t.teamNumber);\n      const blueTeams = match.teams\n        .filter(t => getTeamAlliance(t.station) === 'blue')\n        .map(t => t.teamNumber);\n\n      const redOPR = redTeams.reduce((s, n) => s + (teamOPRs.get(n) ?? 0), 0);\n      const blueOPR = blueTeams.reduce((s, n) => s + (teamOPRs.get(n) ?? 0), 0);\n      const diff = redOPR - blueOPR;\n\n      const predictedWinner: 'red' | 'blue' | 'tie' =\n        Math.abs(diff) < 0.5 ? 'tie' : diff > 0 ? 'red' : 'blue';\n\n      const actualRed = extractScore(match.scores?.red);\n      const actualBlue = extractScore(match.scores?.blue);\n      let actualWinner: 'red' | 'blue' | 'tie' | undefined;\n      if (match.hasBeenPlayed) {\n        actualWinner = actualRed > actualBlue ? 'red'\n          : actualBlue > actualRed ? 'blue' : 'tie';\n      }\n\n      return {\n        matchNum: match.matchNum,\n        redTeams,\n        blueTeams,\n        redPredictedScore: redOPR,\n        bluePredictedScore: blueOPR,\n        predictedWinner,\n        actualRedScore: match.hasBeenPlayed ? actualRed : undefined,\n        actualBlueScore: match.hasBeenPlayed ? actualBlue : undefined,\n        actualWinner,\n        hasBeenPlayed: match.hasBeenPlayed,\n      };\n    }),\n    [qualMatches, teamOPRs]\n  );\n\n  const teamStandings = useMemo((): TeamStanding[] => {\n    const map = new Map<number, TeamStanding>();\n\n    const ensureTeam = (num: number) => {\n      if (!map.has(num)) {\n        map.set(num, {\n          teamNumber: num,\n          opr: teamOPRs.get(num) ?? 0,\n          predictedWins: 0, predictedLosses: 0, predictedTies: 0,\n          actualWins: 0, actualLosses: 0, actualTies: 0,\n        });\n      }\n      return map.get(num)!;\n    };\n\n    for (const m of predictedMatches) {\n      for (const t of m.redTeams) {\n        const s = ensureTeam(t);\n        if (m.predictedWinner === 'red') s.predictedWins++;\n        else if (m.predictedWinner === 'blue') s.predictedLosses++;\n        else s.predictedTies++;\n      }\n      for (const t of m.blueTeams) {\n        const s = ensureTeam(t);\n        if (m.predictedWinner === 'blue') s.predictedWins++;\n        else if (m.predictedWinner === 'red') s.predictedLosses++;\n        else s.predictedTies++;\n      }\n\n      if (m.hasBeenPlayed && m.actualWinner) {\n        for (const t of m.redTeams) {\n          const s = ensureTeam(t);\n          if (m.actualWinner === 'red') s.actualWins++;\n          else if (m.actualWinner === 'blue') s.actualLosses++;\n          else s.actualTies++;\n        }\n        for (const t of m.blueTeams) {\n          const s = ensureTeam(t);\n          if (m.actualWinner === 'blue') s.actualWins++;\n          else if (m.actualWinner === 'red') s.actualLosses++;\n          else s.actualTies++;\n        }\n      }\n    }\n\n    return Array.from(map.values());\n  }, [predictedMatches, teamOPRs]);\n\n  const hasResults = eventData?.hasResults || predictedMatches.some(m => m.hasBeenPlayed);\n\n  const fmtDate = (d: string) => {\n    try {\n      return new Date(d).toLocaleDateString('en-US', {\n        month: 'short', day: 'numeric', year: 'numeric',\n      });\n    } catch { return d; }\n  };\n\n  if (loading) {\n    return (\n      <div className=\"event-view neon-card loading-card\">\n        <div className=\"loading-ring\" />\n        <p className=\"loading-label\">Loading event data…</p>\n      </div>\n    );\n  }\n\n  if (error) {\n    return (\n      <div className=\"event-view neon-card error-card\">\n        <h3 className=\"neon-text-pink\">⚠ Could not load event</h3>\n        <p className=\"error-detail\">{error}</p>\n      </div>\n    );\n  }\n\n  if (!eventData) return null;\n\n  const loc = eventData.location;\n  const locStr = [loc.venue, loc.city, loc.state, loc.country].filter(Boolean).join(', ');\n\n  return (\n    <div className=\"event-view\">\n      <div className=\"event-header neon-card\">\n        <div className=\"event-header-inner\">\n          <div className=\"event-info-block\">\n            <h2 className=\"event-title\">{eventData.name}</h2>\n            <div className=\"event-meta-row\">\n              {locStr && <span>📍 {locStr}</span>}\n              <span>📅 {fmtDate(eventData.start)} – {fmtDate(eventData.end)}</span>\n              <span>🏆 {qualMatches.length} qual match{qualMatches.length !== 1 ? 'es' : ''}</span>\n              {loadingOPRs && (\n                <span className=\"opr-loading-badge\">⏳ Fetching season OPRs…</span>\n              )}\n            </div>\n          </div>\n\n          {hasResults && (\n            <div className=\"view-toggle-group\">\n              <button\n                className={`view-toggle-btn${viewMode === 'predicted' ? ' active-predicted' : ''}`}\n                onClick={() => setViewMode('predicted')}\n              >\n                🔮 Predicted\n              </button>\n              <button\n                className={`view-toggle-btn${viewMode === 'actual' ? ' active-actual' : ''}`}\n                onClick={() => setViewMode('actual')}\n              >\n                📊 Actual\n              </button>\n            </div>\n          )}\n        </div>\n      </div>\n\n      <div className=\"event-content-grid\">\n        <section className=\"rankings-panel\">\n          <TeamRankings standings={teamStandings} viewMode={viewMode} />\n        </section>\n        <section className=\"matches-panel\">\n          <MatchList matches={predictedMatches} viewMode={viewMode} teamOPRs={teamOPRs} />\n        </section>\n      </div>\n    </div>\n  );\n};\n\nexport default EventView;\n","import React, { useState } from 'react';\nimport EventSearch from './components/EventSearch';\nimport EventView from './components/EventView';\nimport { EventSearchResult } from './types';\nimport './styles/neon-theme.css';\nimport './index.css';\n\nconst App: React.FC = () => {\n  const [selectedEvent, setSelectedEvent] = useState<EventSearchResult | null>(null);\n\n  return (\n    <div className=\"app-container\">\n      <header className=\"app-header\">\n        <div className=\"header-content\">\n          <span className=\"header-icon\">⚡</span>\n          <div className=\"header-text\">\n            <h1 className=\"app-title\">FTC EVENT PREDICTOR</h1>\n            <p className=\"app-subtitle\">OPR-based match outcome prediction</p>\n          </div>\n        </div>\n      </header>\n\n      <main className=\"main-content\">\n        <EventSearch onEventSelect={setSelectedEvent} />\n\n        {selectedEvent && (\n          <EventView\n            key={`${selectedEvent.code}-${selectedEvent.season}`}\n            eventCode={selectedEvent.code}\n            season={selectedEvent.season}\n            eventName={selectedEvent.name}\n          />\n        )}\n      </main>\n\n      <footer className=\"app-footer\">\n        <p>\n          Data from{' '}\n          <span className=\"neon-text-cyan\">FTCScout</span>\n          {' '}· Season OPR used for all predictions\n        </p>\n      </footer>\n    </div>\n  );\n};\n\nexport default App;\n","import React from 'react';\nimport ReactDOM from 'react-dom';\nimport App from './App';\nimport './index.css';\n\nReactDOM.render(\n  <React.StrictMode>\n    <App />\n  </React.StrictMode>,\n  document.getElementById('root')\n);","// extracted by mini-css-extract-plugin"]}}